# Chess LLM Benchmark Configuration

stockfish:
  path: /usr/games/stockfish
  depth: 22
  threads: 1
  workers: 24  # Parallel Stockfish instances

ollama:
  base_url: http://localhost:11434
  timeout: 180
  max_retries: 3

models:
  - qwen2.5:7b
  - qwen2.5:14b
  - llama3.2:3b
  - llama3.2:8b
  - mistral:7b
  - phi4:14b
  - gemma3:4b
  - gemma3:12b

dataset:
  lichess_source: local  # "api" or "local"
  lichess_csv_path: data/lichess_puzzles.csv
  pgn_path: data/games.pgn

benchmark:
  max_positions_per_tier: 0  # 0 = unlimited (use all ~1.45M per tier)
  random_seed: 42
  prompt_formats:
    - fen_only
    - pgn+fen
    - cot

evaluation:
  cpl_threshold: 50
  centipawn_eval_range:
    min: -2000
    max: 2000

workers:
  count: 4

correction_loop:
  enabled: true
  control_group: true
  max_attempts: 2

paths:
  data_dir: data
  jobs_db: jobs/jobs.db
  results_file: results/evaluations.jsonl
  logs_dir: results/logs
  plots_dir: results/plots
  metrics_dir: results/metrics
